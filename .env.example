# notebooklm-mcp-agent - Environment Variables Reference
# Copy this file to .env and fill in your values.

# Transport
# stdio: local MCP clients; http: remote MCP and OpenAPI clients.
NOTEBOOKLM_MCP_TRANSPORT=stdio

# HTTP server
NOTEBOOKLM_MCP_HTTP_HOST=127.0.0.1
NOTEBOOKLM_MCP_HTTP_PORT=8080
NOTEBOOKLM_MCP_HTTP_PATH=/mcp
NOTEBOOKLM_MCP_STATELESS_HTTP=true
# Public URL used in OpenAPI schemas, plugin manifests, and OAuth redirects.
# NOTEBOOKLM_MCP_BASE_URL=https://your-server.example.com

# Authentication
# none: stdio or loopback HTTP only; bearer: bearer token; github-oauth: GitHub OAuth login.
NOTEBOOKLM_MCP_AUTH_MODE=none
# Required when auth_mode=bearer. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
# NOTEBOOKLM_MCP_BEARER_TOKEN=your-secure-token-here

# GitHub OAuth
# Required when auth_mode=github-oauth.
# NOTEBOOKLM_MCP_GITHUB_CLIENT_ID=your-github-oauth-app-client-id
# NOTEBOOKLM_MCP_GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
NOTEBOOKLM_MCP_GITHUB_REDIRECT_PATH=/auth/callback
NOTEBOOKLM_MCP_OAUTH_REQUIRED_SCOPES=read:user,user:email
# Comma-separated GitHub usernames allowed to authenticate. Empty is invalid.
NOTEBOOKLM_MCP_OAUTH_ALLOWED_USERS=oaslananka

# Docker Compose host auth directory and mount mode.
# Keep writable for long-running servers so notebooklm-py can persist refreshed cookies.
# NOTEBOOKLM_AUTH_FILE=~/.config/notebooklm-agent
NOTEBOOKLM_AUTH_MOUNT_MODE=rw

# NotebookLM authentication
# Option 1: auth file path. Run `notebooklm-agent login` to create it.
# If this file is missing, the server also checks ~/.notebooklm/profiles/default/storage_state.json.
NOTEBOOKLM_MCP_NOTEBOOKLM_AUTH_FILE=~/.config/notebooklm-agent/notebooklm_auth.json
# Option 2: inline JSON for Docker/cloud environments.
# NOTEBOOKLM_MCP_NOTEBOOKLM_AUTH_JSON={"cookies":[]}

# Data storage
NOTEBOOKLM_MCP_DATA_DIR=~/.local/share/notebooklm-agent
# SQLite session DB. {DATA_DIR} is replaced at runtime.
# NOTEBOOKLM_MCP_SESSION_DB=sqlite+aiosqlite:///{DATA_DIR}/sessions.db

# Logging
NOTEBOOKLM_MCP_LOG_FORMAT=json
NOTEBOOKLM_MCP_LOG_LEVEL=INFO

# Safety
NOTEBOOKLM_MCP_DESTRUCTIVE_REQUIRES_CONFIRM=true

# Artifact generation polling
NOTEBOOKLM_MCP_DEFAULT_POLL_INTERVAL_SEC=15
NOTEBOOKLM_MCP_DEFAULT_POLL_TIMEOUT_SEC=600
